enum Color {
    Red,
    Green,
    Blue,
}

enum Shape {
    Circle(int),
    Rect(int, int),
}

fn main() {
    let r = Red;
    let g = Green;
    let b = Blue;

    match r {
        Red => assert(true),
        Green => assert(false),
        Blue => assert(false),
    }

    let c = Circle(10);
    match c {
        Circle(radius) => assert(radius == 10),
        Rect(_w, _h) => assert(false),
    }

    let sq = Rect(5, 3);
    match sq {
        Circle(_) => assert(false),
        Rect(w, h) => assert(w == 5 && h == 3),
    }
}
