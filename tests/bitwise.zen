// Tests for bitwise operators

fn main() {
    // & (bitwise AND)
    assert(12 & 10 == 8);     // 1100 & 1010 = 1000
    assert(255 & 15 == 15);   // 11111111 & 00001111 = 00001111
    assert(0 & 255 == 0);     // 0 & anything = 0

    // | (bitwise OR)
    assert(12 | 10 == 14);    // 1100 | 1010 = 1110
    assert(0 | 255 == 255);   // 0 | 11111111 = 11111111
    assert(5 | 3 == 7);       // 101 | 011 = 111

    // ^ (bitwise XOR)
    assert(12 ^ 10 == 6);     // 1100 ^ 1010 = 0110
    assert(255 ^ 255 == 0);   // anything XOR itself = 0
    assert(0 ^ 255 == 255);   // 0 ^ anything = anything

    // ~ (bitwise NOT / complement)
    assert(~0 == -1);         // !0 = all bits set = -1 in two's complement
    assert(~(-1) == 0);       // !(-1) = 0

    // << (shift left)
    assert(1 << 0 == 1);
    assert(1 << 1 == 2);
    assert(1 << 4 == 16);
    assert(3 << 2 == 12);     // 11 << 2 = 1100

    // >> (shift right)
    assert(16 >> 0 == 16);
    assert(16 >> 1 == 8);
    assert(16 >> 4 == 1);
    assert(12 >> 2 == 3);     // 1100 >> 2 = 11

    // Combined bitwise operations
    let flags = 0;
    let read = 1;
    let write = 2;
    let exec = 4;

    // Set flags using OR
    flags = flags | read;
    assert(flags == 1);

    flags = flags | write;
    assert(flags == 3);        // 01 | 10 = 11

    flags = flags | exec;
    assert(flags == 7);        // 011 | 100 = 111

    // Check flags using AND
    assert((flags & read) != 0);    // has read
    assert((flags & write) != 0);   // has write
    assert((flags & exec) != 0);    // has exec

    // Clear a flag using AND + NOT
    flags = flags & ~write;
    assert(flags == 5);        // 111 & !010 = 111 & 101 = 101
    assert((flags & write) == 0);   // write is cleared

    // Toggle a flag using XOR
    flags = flags ^ exec;
    assert(flags == 1);        // 101 ^ 100 = 001
    flags = flags ^ exec;
    assert(flags == 5);        // 001 ^ 100 = 101

    // Shift operations for power of 2 checks
    let power = 1 << 10;
    assert(power == 1024);

    // Chained shifts
    assert(1 << 3 >> 1 == 4);  // 8 >> 1 = 4

    // Bitwise with compound assignment (use = x & y form to avoid &= bug)
    let x = 0xFF;
    x = x & 0x0F;
    assert(x == 15);

    let y = 3;
    y <<= 4;
    assert(y == 48);

    let z = 128;
    z >>= 3;
    assert(z == 16);
}
