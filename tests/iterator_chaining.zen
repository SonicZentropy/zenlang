// Method chaining on iterators: iter(arr).map(f).filter(g).collect()

// 1. Basic chain
let result = iter([1, 2, 3, 4, 5])
    .map(|x| x * 2)
    .filter(|x| x > 4)
    .collect();
assert_eq(result, [6, 8, 10]);

// 2. Chain starting from range
let r = iter(0..10)
    .take(5)
    .collect();
assert_eq(r, [0, 1, 2, 3, 4]);

// 3. Fold via method
let total = iter([1, 2, 3, 4, 5])
    .fold(0, |acc, x| acc + x);
assert_eq(total, 15);

// 4. Count via method
let n = iter([10, 20, 30])
    .count();
assert_eq(n, 3);

// 5. Sum via method
let s = iter([1, 2, 3, 4, 5])
    .sum();
assert_eq(s, 15);

// 6. Product via method
let p = iter([1, 2, 3, 4])
    .product();
assert_eq(p, 24);

// 7. All / Any via method
let all_pos = iter([1, 2, 3])
    .all(|x| x > 0);
assert_eq(all_pos, true);

let any_gt2 = iter([1, 2, 3])
    .any(|x| x > 2);
assert_eq(any_gt2, true);
assert_eq(iter([1, 2, 3]).any(|x| x > 10), false);

// 8. Find / Position via method
let found = iter([10, 20, 30])
    .find(|x| x > 15);
assert_eq(found, Some(20));

let pos = iter([10, 20, 30])
    .position(|x| x > 15);
assert_eq(pos, Some(1));

// 9. Enumerate via method
let pairs = iter(["a", "b", "c"])
    .enumerate()
    .collect();
assert_eq(pairs[0][0], 0);
assert_eq(pairs[0][1], "a");

// 10. Chain via method
let chained = iter([1, 2])
    .chain([3, 4])
    .collect();
assert_eq(chained, [1, 2, 3, 4]);

// 11. Zip via method
let zipped = iter([1, 2, 3])
    .zip(["a", "b", "c"])
    .collect();
assert_eq(zipped[0][0], 1);
assert_eq(zipped[0][1], "a");

// 12. Skip via method
let skipped = iter([1, 2, 3, 4, 5])
    .skip(2)
    .collect();
assert_eq(skipped, [3, 4, 5]);

// 13. Step by via method
let stepped = iter([1, 2, 3, 4, 5, 6])
    .step_by(2)
    .collect();
assert_eq(stepped, [1, 3, 5]);

// 14. Inspect (side-effect, just make sure it works)
let mut side = 0;
iter([1, 2, 3])
    .inspect(|x| { side = side + x; })
    .collect();
assert_eq(side, 6);

// 15. Flat map via method
let expanded = iter([1, 2, 3])
    .flat_map(|x| [x, x * 10])
    .collect();
assert_eq(expanded, [1, 10, 2, 20, 3, 30]);

// 16. Scan via method
let running = iter([1, 2, 3, 4])
    .scan(0, |acc, x| acc + x)
    .collect();
assert_eq(running, [1, 3, 6, 10]);

// 17. Partition via method
let parts = iter([1, 2, 3, 4, 5])
    .partition(|x| x % 2 == 0);
assert_eq(parts[0], [2, 4]);
assert_eq(parts[1], [1, 3, 5]);

// 18. String join via method
let joined = iter(["a", "b", "c"])
    .join(", ");
assert_eq(joined, "a, b, c");

// 19. Min / Max via method
let vals = [3, 1, 4, 1, 5, 9];
assert_eq(iter(vals).min(), Some(1));
assert_eq(iter(vals).max(), Some(9));
assert_eq(iter([]).min(), None);
assert_eq(iter([]).max(), None);

print("All iterator chaining tests passed!");
