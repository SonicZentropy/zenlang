fn main() {
    // if / else
    let x = 10;
    if x > 5 {
        assert(true);
    } else {
        assert(false);
    }

    let y = if x > 0 { 1 } else { 0 };
    assert(y == 1);

    // nested if in else
    let z = if x > 100 { 3 } else {
        if x > 50 { 2 } else { 1 }
    };
    assert(z == 1);

    // while
    let mut count = 0;
    while count < 5 {
        count = count + 1;
    }
    assert(count == 5);

    // loop + break
    let mut n = 0;
    loop {
        n = n + 1;
        if n >= 10 { break; }
    }
    assert(n == 10);

    // loop + continue
    let mut sum = 0;
    let mut i = 0;
    loop {
        i = i + 1;
        if i > 10 { break; }
        if i % 2 == 0 { continue; }
        sum = sum + i;
    }
    assert(sum == 25); // 1+3+5+7+9

    // for over range
    let mut s = 0;
    for i in 0..5 {
        s = s + i;
    }
    assert(s == 10); // 0+1+2+3+4

    // for over inclusive range
    let mut t = 0;
    for i in 0..=5 {
        t = t + i;
    }
    assert(t == 15); // 0+1+2+3+4+5

    // match with literal patterns
    let v = 2;
    match v {
        1 => assert(false),
        2 => assert(true),
        _ => assert(false),
    }

    // match with string pattern
    let s2 = "hello";
    match s2 {
        "world" => assert(false),
        "hello" => assert(true),
        _ => assert(false),
    }

    // match with guard
    let g = 7;
    match g {
        n if n > 5 => assert(true),
        _ => assert(false),
    }

    // match returning value
    let val = match x {
        1 => 10,
        2 => 20,
        _ => 30,
    };
    assert(val == 30);

    // nested if inside match arm
    let w = 3;
    match w {
        1 => assert(false),
        _ => {
            if w == 3 {
                assert(true);
            } else {
                assert(false);
            }
        }
    }
}
