// Test enum variant construction and pattern matching

// Define a simple enum
enum Color {
    Red,
    Green,
    Blue
}

// Define an enum with data
enum Option<T> {
    Some(T),
    None
}

// Define an enum with multiple data fields
enum Result<T, E> {
    Ok(T),
    Err(E)
}

// Test basic enum variant construction
let red = Color::Red;
let green = Color::Green;
let blue = Color::Blue;

// Test Option variant construction
let some_number = Option::Some(42);
let no_value = Option::None;

// Test Result variant construction
let ok_value = Result::Ok("success");
let error_value = Result::Err("something went wrong");

// Test pattern matching with enums
fn describe_color(c: Color) -> str {
    match c {
        Color::Red => "red",
        Color::Green => "green",
        Color::Blue => "blue"
    }
}

fn is_some(opt: Option<i32>) -> bool {
    match opt {
        Option::Some(_) => true,
        Option::None => false
    }
}

fn unwrap_or(opt: Option<i32>, default: i32) -> i32 {
    match opt {
        Option::Some(value) => value,
        Option::None => default
    }
}

fn divide(a: i32, b: i32) -> Result<i32, str> {
    if b == 0 {
        Result::Err("division by zero")
    } else {
        Result::Ok(a / b)
    }
}

// Test the functions
let color_desc = describe_color(Color::Green);
let has_value = is_some(Option::Some(10));
let no_value_flag = is_some(Option::None);
let unwrapped = unwrap_or(Option::Some(5), 0);
let default_unwrapped = unwrap_or(Option::None, 42);

// Test division
let div_result = divide(10, 2);
let div_error = divide(5, 0);

// Assertions for testing
assert(color_desc == "green");
assert(has_value == true);
assert(no_value_flag == false);
assert(unwrapped == 5);
assert(default_unwrapped == 42);

// Test that we can extract values from Result
let div_ok = match div_result {
    Result::Ok(value) => value,
    Result::Err(_) => 0
};
assert(div_ok == 5);

// Test error case
let has_error = match div_error {
    Result::Ok(_) => false,
    Result::Err(_) => true
};
assert(has_error == true);