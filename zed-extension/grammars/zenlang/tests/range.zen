fn main() {
    // Exclusive range
    let r = 1..10;
    assert(r[0] == 1);
    assert(r[5] == 6);
    assert(len(r) == 9);

    // Inclusive range
    let ri = 1..=10;
    assert(ri[0] == 1);
    assert(ri[9] == 10);
    assert(len(ri) == 10);

    // for loop over range literal still works
    let mut sum = 0;
    for i in 0..4 {
        sum = sum + i;
    }
    assert(sum == 6);

    // for loop over range variable
    let r2 = 3..7;
    let mut sum2 = 0;
    for i in r2 {
        sum2 = sum2 + i;
    }
    assert(sum2 == 18);
}
